# Host-run app (mvn spring-boot:run). In docker these point at service names instead.
SERVER_PORT=8080

MYSQL_HOST=localhost
MYSQL_PORT=3316
MYSQL_DATABASE=ticket_app
MYSQL_USER=ticket
MYSQL_PASSWORD=ticket
MYSQL_ROOT_PASSWORD=root

REDIS_HOST=localhost
REDIS_PORT=6319

KAFKA_BOOTSTRAP_SERVERS=localhost:9094
KAFKA_UI_PORT=8081

PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

LOGSTASH_HOST=localhost
LOGSTASH_PORT=5000
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601

# Dockerized app instances behind nginx (--profile app)
APP_1_PORT=8091
APP_2_PORT=8092
APP_GATEWAY_PORT=8080

JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes

SEPAY_ACCOUNT_NUMBER=
SEPAY_BANK_CODE=
SEPAY_WEBHOOK_SECRET=
SEPAY_WEBHOOK_REQUIRE_SIGNATURE=true

# Email / SMTP. Defaults target the bundled Mailpit inbox (no credentials).
# For a real provider set MAIL_HOST/PORT/USERNAME/PASSWORD and both flags to true.
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
MAIL_FROM=no-reply@ticketapp.local
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# Performance / tuning levers (Phase 12)
RESERVE_LIMIT=20
MYSQL_FLUSH_LOG=1
HIKARI_POOL_SIZE=80
TOMCAT_ACCEPT_COUNT=100
TOMCAT_MAX_CONNECTIONS=8192
TOMCAT_MAX_THREADS=200
VIRTUAL_THREADS=true
LOG_LEVEL_APP=INFO
APP_JAVA_OPTS=-Xmx768m
