SERVER_PORT=8080

MYSQL_HOST=localhost
MYSQL_PORT=3316
MYSQL_DATABASE=ticket_app
MYSQL_USER=ticket
MYSQL_PASSWORD=ticket
MYSQL_ROOT_PASSWORD=root

REDIS_HOST=localhost
REDIS_PORT=6319

KAFKA_BOOTSTRAP_SERVERS=localhost:9094
KAFKA_UI_PORT=8081

PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

LOGSTASH_HOST=localhost
LOGSTASH_PORT=5000
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601

JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes

# Phase 12 pass 1 tuning levers. Each defaults to current behaviour; set one per
# benchmark run and record the delta in docs/performance-report.md.
# MYSQL_FLUSH_LOG=2 trades <=1s durability on OS crash for fewer fsyncs. Bench only.
MYSQL_FLUSH_LOG=1
HIKARI_POOL_SIZE=80
TOMCAT_ACCEPT_COUNT=100
TOMCAT_MAX_CONNECTIONS=8192
TOMCAT_MAX_THREADS=200
VIRTUAL_THREADS=true
LOG_LEVEL_APP=INFO
APP_JAVA_OPTS=-Xmx768m
