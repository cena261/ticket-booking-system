# Copy to environment/.env (gitignored) before running docker compose.
# Host ports are offset from defaults to avoid clashing with local services.

MYSQL_PORT=3316
MYSQL_DATABASE=ticket_app
MYSQL_USER=ticket
MYSQL_PASSWORD=ticket
MYSQL_ROOT_PASSWORD=root

REDIS_PORT=6319

# Kafka host port is fixed at 9094 (tied to the advertised EXTERNAL listener), not tunable here.
KAFKA_UI_PORT=8081
