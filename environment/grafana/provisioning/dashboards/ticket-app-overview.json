{
  "id": null,
  "uid": "ticket-app-overview",
  "title": "Ticket App - Overview",
  "tags": ["ticket-app", "buy-path"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(jvm_info{job=\"ticket-app\"}, instance)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "HTTP",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "HTTP request rate by status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(http_server_requests_seconds_count{job=\"ticket-app\", instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP p95 latency by uri",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket{job=\"ticket-app\", instance=~\"$instance\"}[1m])))",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Buy path (business KPIs)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "type": "timeseries",
      "title": "Reserve rate by outcome",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (mode, outcome) (rate(ticket_reserve_seconds_count{instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{mode}} / {{outcome}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Reserve latency (p50 / p95 / p99)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(ticket_reserve_seconds_bucket{instance=~\"$instance\"}[1m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ticket_reserve_seconds_bucket{instance=~\"$instance\"}[1m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(ticket_reserve_seconds_bucket{instance=~\"$instance\"}[1m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Oversell prevented (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(ticket_oversell_prevented_total{instance=~\"$instance\"})",
          "legendFormat": "prevented"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Outbox pending (async settlement backlog)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(ticket_outbox_pending{instance=~\"$instance\"})",
          "legendFormat": "pending rows"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Kafka consumer lag",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kafka_consumer_fetch_manager_records_lag{job=\"ticket-app\", instance=~\"$instance\"})",
          "legendFormat": "records lag"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "L1 cache hit ratio (0 until Phase 8c)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ticket_cache_requests_total{level=\"l1\", result=\"hit\", instance=~\"$instance\"}[5m])) / clamp_min(sum(rate(ticket_cache_requests_total{level=\"l1\", instance=~\"$instance\"}[5m])), 1)",
          "legendFormat": "l1 hit ratio"
        }
      ]
    },
    {
      "type": "row",
      "title": "JVM & DB pool",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 }
    },
    {
      "type": "timeseries",
      "title": "JVM heap used",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 25 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (instance) (jvm_memory_used_bytes{job=\"ticket-app\", area=\"heap\", instance=~\"$instance\"})",
          "legendFormat": "{{instance}} heap used"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "GC pause rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 25 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (instance) (rate(jvm_gc_pause_seconds_sum{job=\"ticket-app\", instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{instance}} gc pause/s"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HikariCP connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 25 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "hikaricp_connections_active{job=\"ticket-app\", instance=~\"$instance\"}",
          "legendFormat": "active"
        },
        {
          "refId": "B",
          "expr": "hikaricp_connections_idle{job=\"ticket-app\", instance=~\"$instance\"}",
          "legendFormat": "idle"
        },
        {
          "refId": "C",
          "expr": "hikaricp_connections_pending{job=\"ticket-app\", instance=~\"$instance\"}",
          "legendFormat": "pending"
        }
      ]
    }
  ]
}
