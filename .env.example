# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# Phase 1 boots without any of these; they are consumed from Phase 2 onward.

# App
SERVER_PORT=8080

# MySQL (Phase 2/3)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=ticket_app
MYSQL_USER=ticket
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-root

# Redis (Phase 2/5)
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka (Phase 2/6)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
